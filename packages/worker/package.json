{
  "name": "@autocut/worker",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --out-dir dist --no-splitting --external @prisma/client",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@autocut/database": "workspace:*",
    "@autocut/shared": "workspace:*",
    "bullmq": "^5.7.0",
    "ioredis": "^5.3.2",
    "@aws-sdk/client-s3": "^3.582.0",
    "fluent-ffmpeg": "^2.1.3",
    "winston": "^3.13.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.5",
    "tmp": "^0.2.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/tmp": "^0.2.6",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.12.0",
    "tsx": "^4.10.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.0"
  }
}
