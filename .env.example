# ============================================================
# AutoCut Pro — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================================
# Database
# ============================================================
DATABASE_URL="postgresql://autocut:password@localhost:5432/autocut_pro"

# ============================================================
# Redis
# ============================================================
REDIS_URL="redis://localhost:6379"

# ============================================================
# S3/R2 Storage (Cloudflare R2 recommended)
# ============================================================
S3_BUCKET_NAME="autocut-pro-videos"
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# For Cloudflare R2:
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# For AWS S3, leave S3_ENDPOINT blank
# S3_ENDPOINT=""
S3_PUBLIC_URL="https://your-bucket.r2.dev"
S3_FORCE_PATH_STYLE="false"

# ============================================================
# Auth (API — Express JWT)
# ============================================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ============================================================
# NextAuth (Web — Next.js)
# ============================================================
NEXTAUTH_SECRET="your-nextauth-secret-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# API URLs
# ============================================================
# Public URL (used by browser)
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Server-side URL (used by Next.js API routes)
API_URL="http://localhost:4000"

# ============================================================
# FFmpeg (Worker)
# ============================================================
FFMPEG_PATH="/usr/bin/ffmpeg"
FFPROBE_PATH="/usr/bin/ffprobe"

# ============================================================
# Worker Settings
# ============================================================
WORKER_CONCURRENCY=2
TEMP_DIR="/tmp/autocut"
LOG_DIR="logs"
LOG_LEVEL="info"

# ============================================================
# Upload Limits
# ============================================================
MAX_UPLOAD_SIZE_MB=2048
MAX_FREE_VIDEOS_PER_MONTH=5
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=2048

# ============================================================
# Admin
# ============================================================
ADMIN_EMAIL="admin@autocut.pro"

# ============================================================
# Stripe (optional — for payments)
# ============================================================
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ============================================================
# Server
# ============================================================
PORT=4000
NODE_ENV="development"
